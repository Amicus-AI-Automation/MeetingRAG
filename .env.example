# ============================================================
# MeetingRAG — Environment Variables
# Copy this file to .env and fill in your real values.
# .env is NOT committed to git (listed in .gitignore).
# ============================================================

# ── Azure Entra ID ───────────────────────────────────────────
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# ── React (baked in at image build time) ────────────────────
# These are passed as Docker build-args, NOT runtime env vars.
REACT_APP_AZURE_TENANT_ID=your-tenant-id-here
REACT_APP_AZURE_CLIENT_ID=your-client-id-here
REACT_APP_API_URL=http://localhost:5000

# ── LLM ─────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here
OPENROUTER_API_KEY=

# ── Backend ──────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
PORT=5000
CORS_ORIGIN=http://localhost:3000

# ── Python API ───────────────────────────────────────────────
PYTHON_API_URL=http://python-api:8000

# ── MongoDB ──────────────────────────────────────────────────
MONGO_URI=mongodb://mongodb:27017/meetingrag

# ── Ollama ───────────────────────────────────────────────────
OLLAMA_URL=http://ollama:11434/api/generate

# ── Storage paths inside containers ─────────────────────────
CHROMA_PATH=/data/chroma_db
UPLOAD_DIR=/uploads
